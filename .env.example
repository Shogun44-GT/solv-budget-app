# ─── Application ───────────────────────────────────────────
APP_NAME="Coach Budget IA"
APP_ENV=development
DEBUG=true
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

# ─── Base de données ───────────────────────────────────────
POSTGRES_USER=coachbudget
POSTGRES_PASSWORD=coachbudget_secret
POSTGRES_DB=coachbudget_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://coachbudget:coachbudget_secret@db:5432/coachbudget_db

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── APIs tierces ──────────────────────────────────────────
OPENFOODFACTS_API_URL=https://world.openfoodfacts.org/api/v2
NOMINATIM_API_URL=https://nominatim.openstreetmap.org

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── Frontend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_APP_NAME="Coach Budget IA"
